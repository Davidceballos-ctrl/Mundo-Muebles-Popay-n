#  4. En Vercel: agrega estas variables en Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────
# Encuéntralas en: tu proyecto Supabase → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sal de seguridad ──────────────────────────────────────────────────
# Cadena secreta usada al hashear contraseñas. Cámbiala por algo único.
# ⚠️ NO cambies este valor una vez en producción — los hashes cambiarían.
VITE_APP_SALT=MundoMueblesPopayan2025#Sec
